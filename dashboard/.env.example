# Conduit dashboard → Proxmox VE. Server-side only (never exposed to the client).
# Copy to .env.local and fill in. The SSH password reuses PROXMOX_PASS unless
# PROXMOX_SSH_PASS is set; provisioning SSHes to the node as root to run `pct exec`.
PROXMOX_HOST=10.0.0.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_PASS=changeme
PROXMOX_NODE=pve

# Preferred API auth: a revocable PVE token (CSRF-exempt). If set, used instead of
# the password for all HTTP API calls. Create with:
#   pveum user token add root@pam conduit --privsep 0
# PROXMOX_TOKEN_ID=root@pam!conduit
# PROXMOX_TOKEN_SECRET=00000000-0000-0000-0000-000000000000

# in-container provisioning over SSH (pct exec). Prefer key auth — generate a key,
# install the .pub in the node's root authorized_keys, and point at the private key:
#   ssh-keygen -t ed25519 -f ~/.conduit/conduit_ed25519 -N ""
#   ssh-copy-id -i ~/.conduit/conduit_ed25519.pub root@<node>
# PROXMOX_SSH_KEY=/home/you/.conduit/conduit_ed25519
# PROXMOX_SSH_HOST=10.0.0.10
# PROXMOX_SSH_USER=root
# PROXMOX_SSH_PASS=changeme   # fallback if no key configured

# set to "off" to run the dashboard without the reconcile controller loop
# CONDUIT_CONTROLLER=off
